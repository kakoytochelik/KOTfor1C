Функция СформироватьСнимокФормы(Форма, Параметры = Неопределено) Экспорт

    Настройки = НормализоватьПараметры(Параметры);
    МетаданныеФормы = ПолучитьСтроковыйПараметр(Настройки, "MetadataPath");
    ЗаголовокОкна = ПолучитьСтроковыйПараметр(Настройки, "WindowTitle");
    Источник = ПолучитьПараметр(Настройки, "Source");
    ВключатьТабличныеИсточники = ПолучитьБулевыйПараметр(Настройки, "IncludeTables", Истина);
    ВключатьТабличныеДанныеЭлементов = ПолучитьБулевыйПараметр(Настройки, "IncludeElementTableData", ВключатьТабличныеИсточники);
    ПредпочтительныйПутьЭлементаТаблицы = ПолучитьСтроковыйПараметр(Настройки, "PreferElementPathForTableData");
    ВключатьЗначенияЭлементов = ПолучитьБулевыйПараметр(Настройки, "IncludeElementValues", Истина);
    ПредпочтительныйПутьЭлементаЗначения = ПолучитьСтроковыйПараметр(Настройки, "PreferElementPathForValue");

    ПлоскиеЭлементы = СобратьПлоскийСписокЭлементов(
        Форма,
        ВключатьТабличныеДанныеЭлементов,
        ПредпочтительныйПутьЭлементаТаблицы,
        ВключатьЗначенияЭлементов,
        ПредпочтительныйПутьЭлементаЗначения
    );

    Снимок = Новый Структура;
    Снимок.Вставить("schemaVersion", 1);
    Снимок.Вставить("generatedAt", ЗначениеВСтроку(ТекущаяДата()));

    Если Источник <> Неопределено Тогда
        Снимок.Вставить("source", Источник);
    КонецЕсли;

    АтрибутыФормы = СобратьАтрибутыФормы(Форма, ПлоскиеЭлементы);

    Снимок.Вставить("form", СобратьОписаниеФормы(Форма, МетаданныеФормы, ПлоскиеЭлементы, ЗаголовокОкна));
    Снимок.Вставить("elements", ПреобразоватьПлоскийСписокВДерево(ПлоскиеЭлементы));
    Если ВключатьТабличныеИсточники Тогда
        Снимок.Вставить("tables", СобратьТабличныеИсточникиФормы(Форма, ПлоскиеЭлементы, АтрибутыФормы));
    Иначе
        Снимок.Вставить("tables", Новый Массив);
    КонецЕсли;
    Снимок.Вставить("attributes", АтрибутыФормы);
    Снимок.Вставить("commands", СобратьКомандыФормы(Форма));
    Снимок.Вставить("notes", Новый Массив);

    Возврат Снимок;

КонецФункции


Процедура ЗаписатьСнимокФормыВФайл(Форма, ПутьКФайлу, Параметры = Неопределено) Экспорт

    Если Форма = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Если ЭтоПустаяСтрока(СокрЛП(ПутьКФайлу)) Тогда
        Возврат;
    КонецЕсли;

    Снимок = СформироватьСнимокФормы(Форма, Параметры);
    ТекстJSON = ПреобразоватьВJSONСтроку(Снимок);

    ИмяВременногоФайла = ПолучитьИмяВременногоФайла("json");

    ТекстДокумент = Новый ТекстовыйДокумент;
    ТекстДокумент.УстановитьТекст(ТекстJSON);
    ТекстДокумент.Записать(ИмяВременногоФайла, КодировкаТекста.UTF8);

    КопироватьФайл(ИмяВременногоФайла, ПутьКФайлу);

    Попытка
        УдалитьФайлы(ИмяВременногоФайла);
    Исключение
    КонецПопытки;

КонецПроцедуры


Функция НормализоватьПараметры(Параметры)

    Если Параметры = Неопределено Тогда
        Возврат Новый Структура;
    КонецЕсли;

    Возврат Параметры;

КонецФункции


Функция ПолучитьПараметр(Параметры, ИмяПараметра, ЗначениеПоУмолчанию = Неопределено)

    Если Параметры = Неопределено Тогда
        Возврат ЗначениеПоУмолчанию;
    КонецЕсли;

    ЗначениеПараметра = Неопределено;
    Если Параметры.Свойство(ИмяПараметра, ЗначениеПараметра) Тогда
        Возврат ЗначениеПараметра;
    КонецЕсли;

    Возврат ЗначениеПоУмолчанию;

КонецФункции


Функция ПолучитьСтроковыйПараметр(Параметры, ИмяПараметра, ЗначениеПоУмолчанию = "")

    ЗначениеПараметра = ПолучитьПараметр(Параметры, ИмяПараметра, ЗначениеПоУмолчанию);
    Возврат ЗначениеВСтроку(ЗначениеПараметра);

КонецФункции


Функция ПолучитьБулевыйПараметр(Параметры, ИмяПараметра, ЗначениеПоУмолчанию = Ложь)

    ЗначениеПараметра = ПолучитьПараметр(Параметры, ИмяПараметра, ЗначениеПоУмолчанию);

    Попытка
        Если ТипЗнч(ЗначениеПараметра) = Тип("Булево") Тогда
            Возврат ЗначениеПараметра;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Если ЗначениеПараметра = 1 Тогда
        Возврат Истина;
    КонецЕсли;
    Если ЗначениеПараметра = 0 Тогда
        Возврат Ложь;
    КонецЕсли;

    Если НРег(СокрЛП(ЗначениеВСтроку(ЗначениеПараметра))) = "true" Тогда
        Возврат Истина;
    КонецЕсли;
    Если НРег(СокрЛП(ЗначениеВСтроку(ЗначениеПараметра))) = "false" Тогда
        Возврат Ложь;
    КонецЕсли;

    Возврат ЗначениеПоУмолчанию;

КонецФункции


