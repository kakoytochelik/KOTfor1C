Функция ПоследнийСегментПути(Путь)

    Если ЭтоПустаяСтрока(Путь) Тогда
        Возврат "";
    КонецЕсли;

    МассивЧастей = СтрРазделить(Путь, ".");
    Если МассивЧастей.Количество() = 0 Тогда
        Возврат Путь;
    КонецЕсли;

    Возврат МассивЧастей[МассивЧастей.Количество() - 1];

КонецФункции


Функция ПерваяЗаполненнаяСтрока(Значение1 = "", Значение2 = "", Значение3 = "")

