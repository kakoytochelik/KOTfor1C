КонецФункции


Функция СериализоватьКоллекциюСтрок(Коллекция, КолонкиПодсказки = Неопределено)

    Если Коллекция = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    НормализованныеПодсказки = НормализоватьПодсказкиКолонок(КолонкиПодсказки);
    Если НормализованныеПодсказки.Количество() = 0 Тогда
        Возврат Неопределено;
    КонецЕсли;

    МаксимумСтрок = 200;
    Колонки = Новый Массив;
    КлючиКолонок = Новый Массив;

    Для Каждого ПодсказкаКолонки Из НормализованныеПодсказки Цикл
        СписокКлючей = ПолучитьПараметр(ПодсказкаКолонки, "keys");
        Если СписокКлючей = Неопределено Или СписокКлючей.Количество() = 0 Тогда
            Продолжить;
        КонецЕсли;

        ЗаголовокКолонки = ПерваяЗаполненнаяСтрока(
            ПолучитьСтрокуИзСтруктуры(ПодсказкаКолонки, "title"),
            ЗначениеВСтроку(СписокКлючей[0]),
            "Column" + ЗначениеВСтроку(Колонки.Количество() + 1)
        );
        Колонки.Добавить(ЗаголовокКолонки);
        КлючиКолонок.Добавить(СписокКлючей);
    КонецЦикла;

    Если Колонки.Количество() = 0 Тогда
        Возврат Неопределено;
    КонецЕсли;

    Строки = Новый Массив;
    КоличествоСтрокВсего = 0;

    Попытка
        Для Каждого СтрокаКоллекции Из Коллекция Цикл
            КоличествоСтрокВсего = КоличествоСтрокВсего + 1;

            Если КоличествоСтрокВсего <= МаксимумСтрок Тогда
                ЗначенияСтроки = Новый Массив;
                Для ИндексКолонки = 0 По КлючиКолонок.Количество() - 1 Цикл
                    СписокКлючей = КлючиКолонок[ИндексКолонки];
                    ЗначениеЯчейки = Неопределено;

                    Для Каждого КлючКолонки Из СписокКлючей Цикл
                        ЗначениеЯчейки = ПолучитьЗначениеЯчейкиСтроки(СтрокаКоллекции, КлючКолонки);
                        Если ЗначениеЯчейки <> Неопределено Тогда
                            Прервать;
                        КонецЕсли;
                    КонецЦикла;

                    ЗначенияСтроки.Добавить(ПредставлениеЗначения(ЗначениеЯчейки));
                КонецЦикла;
                Строки.Добавить(ЗначенияСтроки);
            КонецЕсли;
        КонецЦикла;
    Исключение
        КоличествоСтрокВсего = 0;
        Строки = Новый Массив;

        Попытка
            КоличествоЭлементов = Коллекция.Количество();
            Для ИндексСтроки = 0 По КоличествоЭлементов - 1 Цикл
                КоличествоСтрокВсего = ИндексСтроки + 1;
                СтрокаКоллекции = Коллекция.Получить(ИндексСтроки);

                Если КоличествоСтрокВсего <= МаксимумСтрок Тогда
                    ЗначенияСтроки = Новый Массив;
                    Для ИндексКолонки = 0 По КлючиКолонок.Количество() - 1 Цикл
                        СписокКлючей = КлючиКолонок[ИндексКолонки];
                        ЗначениеЯчейки = Неопределено;

                        Для Каждого КлючКолонки Из СписокКлючей Цикл
                            ЗначениеЯчейки = ПолучитьЗначениеЯчейкиСтроки(СтрокаКоллекции, КлючКолонки);
                            Если ЗначениеЯчейки <> Неопределено Тогда
                                Прервать;
                            КонецЕсли;
                        КонецЦикла;

                        ЗначенияСтроки.Добавить(ПредставлениеЗначения(ЗначениеЯчейки));
                    КонецЦикла;
                    Строки.Добавить(ЗначенияСтроки);
                КонецЕсли;
            КонецЦикла;
        Исключение
            Возврат Неопределено;
        КонецПопытки;
    КонецПопытки;

    Результат = Новый Структура;
    Результат.Вставить("columns", Колонки);
    Результат.Вставить("rows", Строки);
    Результат.Вставить("rowCount", КоличествоСтрокВсего);
    Результат.Вставить("truncated", КоличествоСтрокВсего > МаксимумСтрок);

    Возврат Результат;

КонецФункции


Функция НормализоватьПодсказкиКолонок(КолонкиПодсказки)

    Результат = Новый Массив;
    Если КолонкиПодсказки = Неопределено Тогда
        Возврат Результат;
    КонецЕсли;

    Для Каждого Подсказка Из КолонкиПодсказки Цикл
        Если Подсказка = Неопределено Тогда
            Продолжить;
        КонецЕсли;

        СписокКлючей = ПолучитьПараметр(Подсказка, "keys");
        Если СписокКлючей = Неопределено Тогда
            Продолжить;
        КонецЕсли;

        НормализованныеКлючи = УникализироватьСтроковыйМассив(СписокКлючей);
        Если НормализованныеКлючи.Количество() = 0 Тогда
            Продолжить;
        КонецЕсли;

        НормализованнаяПодсказка = Новый Структура;
        НормализованнаяПодсказка.Вставить("title", ПолучитьСтрокуИзСтруктуры(Подсказка, "title"));
        НормализованнаяПодсказка.Вставить("keys", НормализованныеКлючи);
        Результат.Добавить(НормализованнаяПодсказка);
    КонецЦикла;

    Возврат Результат;

КонецФункции


Функция СериализоватьТаблицуЗначений(Таблица)

    Если Таблица = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    МаксимумСтрок = 200;
    Колонки = Новый Массив;
    ИменаКолонок = Новый Массив;

    Попытка
        Для Каждого Колонка Из Таблица.Колонки Цикл
            ИмяКолонки = ПолучитьИмяКолонкиТаблицы(Колонка, Колонки.Количество() + 1);
            Колонки.Добавить(ИмяКолонки);
            ИменаКолонок.Добавить(ПолучитьКлючКолонкиТаблицы(Колонка, ИмяКолонки));
        КонецЦикла;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

    Если Колонки.Количество() = 0 Тогда
        Возврат Неопределено;
    КонецЕсли;

    Строки = Новый Массив;
    КоличествоСтрокВсего = ПолучитьКоличествоСтрокТаблицы(Таблица);
    ИндексСтроки = 0;

    Попытка
        Для Каждого СтрокаТаблицы Из Таблица Цикл
            Если ИндексСтроки < МаксимумСтрок Тогда
                ЗначенияСтроки = Новый Массив;

                Для ИндексКолонки = 0 По ИменаКолонок.Количество() - 1 Цикл
                    КлючКолонки = ИменаКолонок[ИндексКолонки];
                    ЗначениеЯчейки = ПолучитьЗначениеЯчейкиСтроки(СтрокаТаблицы, КлючКолонки);
                    ЗначенияСтроки.Добавить(ПредставлениеЗначения(ЗначениеЯчейки));
                КонецЦикла;

                Строки.Добавить(ЗначенияСтроки);
            КонецЕсли;

            ИндексСтроки = ИндексСтроки + 1;
        КонецЦикла;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

    Результат = Новый Структура;
    Результат.Вставить("columns", Колонки);
    Результат.Вставить("rows", Строки);
    Результат.Вставить("rowCount", КоличествоСтрокВсего);
    Результат.Вставить("truncated", КоличествоСтрокВсего > МаксимумСтрок);

    Возврат Результат;

КонецФункции


Функция ПолучитьКоличествоСтрокТаблицы(Таблица)

    Если Таблица = Неопределено Тогда
        Возврат 0;
    КонецЕсли;

    Попытка
        Возврат Таблица.Количество();
    Исключение
    КонецПопытки;

    Возврат 0;

КонецФункции


Функция ПолучитьИмяКолонкиТаблицы(Колонка, ИндексПоУмолчанию)

    ИмяКолонки = ПерваяЗаполненнаяСтрока(
        ЗначениеВСтроку(ПолучитьЗначениеСвойства(Колонка, "Заголовок")),
        ЗначениеВСтроку(ПолучитьЗначениеСвойства(Колонка, "Title")),
        ПерваяЗаполненнаяСтрока(
            ЗначениеВСтроку(ПолучитьЗначениеСвойства(Колонка, "Имя")),
            ЗначениеВСтроку(ПолучитьЗначениеСвойства(Колонка, "Name"))
        )
    );

    Если ЭтоПустаяСтрока(ИмяКолонки) Тогда
        ИмяКолонки = "Column" + ЗначениеВСтроку(ИндексПоУмолчанию);
    КонецЕсли;

    Возврат ИмяКолонки;

