Функция ПолучитьПредставлениеЗначенияЭлемента(Форма, Элемент, ПутьКДанным)

    КандидатыПутей = ПолучитьКандидатыПутиДанныхЭлемента(Элемент, ПутьКДанным);

    Для Каждого КандидатПути Из КандидатыПутей Цикл
        Значение = ПолучитьЗначениеПоПутиФормы(Форма, КандидатПути);
        Если Значение <> Неопределено Тогда
            Возврат ПредставлениеЗначения(Значение);
        КонецЕсли;
    КонецЦикла;

    Значение = ПолучитьЗначениеЭлементаНапрямую(Элемент);
    Если Значение <> Неопределено Тогда
        Возврат ПредставлениеЗначения(Значение);
    КонецЕсли;

    ИмяЭлемента = ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент));
    Значение = ПолучитьЗначениеФормыПоИмени(Форма, ИмяЭлемента);
    Если Значение <> Неопределено Тогда
        Возврат ПредставлениеЗначения(Значение);
    КонецЕсли;

    Для Каждого КандидатПути Из КандидатыПутей Цикл
        Значение = ПолучитьЗначениеИзТекущихДанныхЭлемента(Элемент, КандидатПути);
        Если Значение <> Неопределено Тогда
            Возврат ПредставлениеЗначения(Значение);
        КонецЕсли;
    КонецЦикла;

    ОтображаемыйТекст = ПолучитьОтображаемыйТекстЭлемента(Элемент);
    Если Не ЭтоПустаяСтрока(ОтображаемыйТекст) Тогда
        Возврат ОтображаемыйТекст;
    КонецЕсли;

    Возврат "";

КонецФункции


Функция ПолучитьКандидатыПутиДанныхЭлемента(Элемент, ПутьКДанным = "")

    Кандидаты = Новый Массив;
    ИмяЭлемента = ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент));

    Если Не ЭтоПустаяСтрока(ПутьКДанным) Тогда
        Кандидаты.Добавить(ПутьКДанным);
    КонецЕсли;

    Если Не ЭтоПустаяСтрока(ИмяЭлемента) Тогда
        Кандидаты.Добавить("Object." + ИмяЭлемента);
        Кандидаты.Добавить(ИмяЭлемента);
    КонецЕсли;

    Возврат УникализироватьСтроковыйМассив(Кандидаты);

КонецФункции


Функция ОпределитьПутьДанныхЭлемента(Форма, Элемент, ПутьКДанным = "")

    Для Каждого КандидатПути Из ПолучитьКандидатыПутиДанныхЭлемента(Элемент, ПутьКДанным) Цикл
        Значение = ПолучитьЗначениеПоПутиФормы(Форма, КандидатПути);
        Если Значение <> Неопределено Тогда
            Возврат КандидатПути;
        КонецЕсли;
    КонецЦикла;

    Возврат ПутьКДанным;

КонецФункции


