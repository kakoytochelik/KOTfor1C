Функция ПолучитьКлючКолонкиТаблицы(Колонка, ИмяКолонки)

    КлючКолонки = ПерваяЗаполненнаяСтрока(
        ЗначениеВСтроку(ПолучитьЗначениеСвойства(Колонка, "Имя")),
        ЗначениеВСтроку(ПолучитьЗначениеСвойства(Колонка, "Name")),
        ИмяКолонки
    );

    Возврат КлючКолонки;

КонецФункции


Функция ПолучитьЗначениеЯчейкиСтроки(СтрокаТаблицы, КлючКолонки)

    Если СтрокаТаблицы = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    Если Не ЭтоПустаяСтрока(КлючКолонки) Тогда
        Попытка
            Возврат СтрокаТаблицы[КлючКолонки];
        Исключение
        КонецПопытки;

        Попытка
            Возврат Вычислить("СтрокаТаблицы." + КлючКолонки);
        Исключение
        КонецПопытки;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции


Функция ПолучитьЗначениеСвойства(Значение, ИмяСвойства)

    Если Значение = Неопределено Или ЭтоПустаяСтрока(ИмяСвойства) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Попытка
        Возврат Значение[ИмяСвойства];
    Исключение
    КонецПопытки;

    Попытка
        Возврат Вычислить("Значение." + ИмяСвойства);
    Исключение
    КонецПопытки;

    Возврат Неопределено;

КонецФункции


Функция ПолучитьКандидатыПутиДанныхЭлемента(Элемент, ПутьКДанным = "")

    Кандидаты = Новый Массив;
    ИмяЭлемента = ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент));
    НормализованныйПуть = НормализоватьПутьДляОбъекта(ПутьКДанным);

    Если Не ЭтоПустаяСтрока(ПутьКДанным) Тогда
        Кандидаты.Добавить(ПутьКДанным);
    КонецЕсли;

    Если Не ЭтоПустаяСтрока(НормализованныйПуть) Тогда
        Кандидаты.Добавить(НормализованныйПуть);
        Кандидаты.Добавить("Object." + НормализованныйПуть);
        Кандидаты.Добавить("Объект." + НормализованныйПуть);
    КонецЕсли;

    Если Не ЭтоПустаяСтрока(ИмяЭлемента) Тогда
        Кандидаты.Добавить("Object." + ИмяЭлемента);
        Кандидаты.Добавить("Объект." + ИмяЭлемента);
        Кандидаты.Добавить("ThisObject." + ИмяЭлемента);
        Кандидаты.Добавить(ИмяЭлемента);
    КонецЕсли;

    Возврат УникализироватьСтроковыйМассив(Кандидаты);

КонецФункции


Функция ОпределитьПутьДанныхЭлемента(Форма, Элемент, ПутьКДанным = "")

    Для Каждого КандидатПути Из ПолучитьКандидатыПутиДанныхЭлемента(Элемент, ПутьКДанным) Цикл
        Значение = ПолучитьЗначениеПоПутиФормы(Форма, КандидатПути);
        Если Значение <> Неопределено Тогда
            Возврат КандидатПути;
        КонецЕсли;
    КонецЦикла;

    Возврат ПутьКДанным;

КонецФункции


