Функция СформироватьСнимокФормы(Форма, Параметры = Неопределено) Экспорт

    Настройки = НормализоватьПараметры(Параметры);
    МетаданныеФормы = ПолучитьСтроковыйПараметр(Настройки, "MetadataPath");
    ЗаголовокОкна = ПолучитьСтроковыйПараметр(Настройки, "WindowTitle");
    Источник = ПолучитьПараметр(Настройки, "Source");

    ПлоскиеЭлементы = СобратьПлоскийСписокЭлементов(Форма);

    Снимок = Новый Структура;
    Снимок.Вставить("schemaVersion", 1);
    Снимок.Вставить("generatedAt", ЗначениеВСтроку(ТекущаяДата()));

    Если Источник <> Неопределено Тогда
        Снимок.Вставить("source", Источник);
    КонецЕсли;

    Снимок.Вставить("form", СобратьОписаниеФормы(Форма, МетаданныеФормы, ПлоскиеЭлементы, ЗаголовокОкна));
    Снимок.Вставить("elements", ПреобразоватьПлоскийСписокВДерево(ПлоскиеЭлементы));
    Снимок.Вставить("attributes", СобратьАтрибутыФормы(Форма, ПлоскиеЭлементы));
    Снимок.Вставить("commands", СобратьКомандыФормы(Форма));
    Снимок.Вставить("notes", Новый Массив);

    Возврат Снимок;

КонецФункции


Процедура ЗаписатьСнимокФормыВФайл(Форма, ПутьКФайлу, Параметры = Неопределено) Экспорт

    Если Форма = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Если ЭтоПустаяСтрока(СокрЛП(ПутьКФайлу)) Тогда
        Возврат;
    КонецЕсли;

    Снимок = СформироватьСнимокФормы(Форма, Параметры);
    ТекстJSON = ПреобразоватьВJSONСтроку(Снимок);

    ИмяВременногоФайла = ПолучитьИмяВременногоФайла("json");

    ТекстДокумент = Новый ТекстовыйДокумент;
    ТекстДокумент.УстановитьТекст(ТекстJSON);
    ТекстДокумент.Записать(ИмяВременногоФайла, КодировкаТекста.UTF8);

    КопироватьФайл(ИмяВременногоФайла, ПутьКФайлу);

    Попытка
        УдалитьФайлы(ИмяВременногоФайла);
    Исключение
    КонецПопытки;

КонецПроцедуры


Функция НормализоватьПараметры(Параметры)

    Если Параметры = Неопределено Тогда
        Возврат Новый Структура;
    КонецЕсли;

    Возврат Параметры;

КонецФункции


Функция ПолучитьПараметр(Параметры, ИмяПараметра, ЗначениеПоУмолчанию = Неопределено)

    Если Параметры = Неопределено Тогда
        Возврат ЗначениеПоУмолчанию;
    КонецЕсли;

    ЗначениеПараметра = Неопределено;
    Если Параметры.Свойство(ИмяПараметра, ЗначениеПараметра) Тогда
        Возврат ЗначениеПараметра;
    КонецЕсли;

    Возврат ЗначениеПоУмолчанию;

КонецФункции


