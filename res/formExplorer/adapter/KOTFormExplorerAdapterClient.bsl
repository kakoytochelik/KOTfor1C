Функция СобратьОписаниеФормы(Форма, МетаданныеФормы, ПлоскиеЭлементы, ЗаголовокОкна = "")

    Описание = Новый Структура;
    ИтоговыйЗаголовок = ПерваяЗаполненнаяСтрока(
        ЗаголовокОкна,
        ЗначениеВСтроку(ПолучитьЗаголовокФормы(Форма))
    );
    Описание.Вставить("title", ИтоговыйЗаголовок);
    Описание.Вставить("windowTitle", ИтоговыйЗаголовок);
    Описание.Вставить("name", ЗначениеВСтроку(ПолучитьИмяФормыДляСнимка(Форма)));
    Описание.Вставить("metadataPath", МетаданныеФормы);
    Описание.Вставить("type", Строка(ТипЗнч(Форма)));
    Описание.Вставить("viewKind", "");
    Описание.Вставить("activeElementPath", ПолучитьПутьАктивногоЭлемента(Форма, ПлоскиеЭлементы));
    Описание.Вставить("notes", Новый Массив);

    Возврат Описание;

КонецФункции


Функция ПолучитьПутьАктивногоЭлемента(Форма, ПлоскиеЭлементы)

    ТекущийЭлемент = ПолучитьТекущийЭлементФормы(Форма);
    Если ТекущийЭлемент <> Неопределено Тогда
        Возврат ПолучитьПутьЭлемента(ТекущийЭлемент);
    КонецЕсли;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        Если ПолучитьБулевоИзСтруктуры(ОписаниеЭлемента, "active", Ложь) Тогда
            Возврат ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "path");
        КонецЕсли;
    КонецЦикла;

    Возврат "";

КонецФункции


Функция СобратьПлоскийСписокЭлементов(
    Форма,
    ВключатьТабличныеДанные = Истина,
    ПредпочтительныйПутьЭлемента = "",
    ВключатьЗначенияЭлементов = Истина,
    ПредпочтительныйПутьЭлементаЗначения = ""
)

    Результат = Новый Массив;
    КоллекцияЭлементов = ПолучитьЭлементыФормы(Форма);

    Если КоллекцияЭлементов = Неопределено Тогда
        Возврат Результат;
    КонецЕсли;

    АктивныйПуть = ПолучитьПутьЭлемента(ПолучитьТекущийЭлементФормы(Форма));

    Попытка
        Для Каждого Элемент Из КоллекцияЭлементов Цикл
            Попытка
                ОписаниеЭлемента = Новый Структура;
                ПутьЭлемента = ПолучитьПутьЭлемента(Элемент);
                ПутьРодителя = ПолучитьПутьЭлемента(ПолучитьРодителяЭлемента(Элемент));
                ПутьКДанным = ПолучитьПутьДанныхЭлемента(Элемент);
                ПутьКДанным = ОпределитьПутьДанныхЭлемента(Форма, Элемент, ПутьКДанным);

                ОписаниеЭлемента.Вставить("path", ПутьЭлемента);
                ОписаниеЭлемента.Вставить("parentPath", ПутьРодителя);
                ОписаниеЭлемента.Вставить("name", ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент)));
                ОписаниеЭлемента.Вставить("title", ПерваяЗаполненнаяСтрока(
                    ЗначениеВСтроку(ПолучитьЗаголовокЭлемента(Элемент)),
                    ЗначениеВСтроку(ПолучитьПодсказкуЭлемента(Элемент)),
                    ЗначениеВСтроку(ПолучитьПодсказкуВводаЭлемента(Элемент))
                ));
                ОписаниеЭлемента.Вставить("synonym", ПерваяЗаполненнаяСтрока(
                    ЗначениеВСтроку(ПолучитьЗаголовокЭлемента(Элемент)),
                    ЗначениеВСтроку(ПолучитьПодсказкуВводаЭлемента(Элемент))
                ));
                ОписаниеЭлемента.Вставить("toolTip", ЗначениеВСтроку(ПолучитьПодсказкуЭлемента(Элемент)));
                ОписаниеЭлемента.Вставить("inputHint", ЗначениеВСтроку(ПолучитьПодсказкуВводаЭлемента(Элемент)));
                ОписаниеЭлемента.Вставить("kind", ПерваяЗаполненнаяСтрока(
                    ЗначениеВСтроку(ПолучитьВидЭлемента(Элемент)),
                    Строка(ТипЗнч(Элемент))
                ));
                ОписаниеЭлемента.Вставить("type", Строка(ТипЗнч(Элемент)));
                ОписаниеЭлемента.Вставить("boundAttributePath", ПутьКДанным);
                ОписаниеЭлемента.Вставить("visible", ПолучитьВидимостьЭлемента(Элемент));
                ОписаниеЭлемента.Вставить("available", ПолучитьДоступностьЭлемента(Элемент));
                ОписаниеЭлемента.Вставить("enabled", ПолучитьДоступностьЭлемента(Элемент));
                ОписаниеЭлемента.Вставить("readOnly", ПолучитьТолькоПросмотрЭлемента(Элемент));
                ОписаниеЭлемента.Вставить("active", ПутьЭлемента = АктивныйПуть);
                СобиратьЗначениеЭлемента = ВключатьЗначенияЭлементов
                    Или (Не ЭтоПустаяСтрока(ПредпочтительныйПутьЭлементаЗначения) И ПутьЭлемента = ПредпочтительныйПутьЭлементаЗначения);
                Если СобиратьЗначениеЭлемента Тогда
                    ОписаниеЭлемента.Вставить("valuePreview", ПолучитьПредставлениеЗначенияЭлемента(Форма, Элемент, ПутьКДанным));
                Иначе
                    ОписаниеЭлемента.Вставить("valuePreview", "");
                КонецЕсли;
                СобиратьТабличныеДанные = ВключатьТабличныеДанные
                    Или (Не ЭтоПустаяСтрока(ПредпочтительныйПутьЭлемента) И ПутьЭлемента = ПредпочтительныйПутьЭлемента);
                Если СобиратьТабличныеДанные Тогда
                    ОписаниеЭлемента.Вставить("tableData", ПолучитьТабличныеДанныеЭлемента(Форма, Элемент, ПутьКДанным));
                    ОписаниеЭлемента.Вставить("tableColumnHints", ПолучитьПодсказкиКолонокТаблицыИзЭлемента(
                        Элемент,
                        ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент))
                    ));
                Иначе
                    ОписаниеЭлемента.Вставить("tableData", Неопределено);
                    ОписаниеЭлемента.Вставить("tableColumnHints", Новый Массив);
                КонецЕсли;
                ОписаниеЭлемента.Вставить("metadataPath", "");
                ОписаниеЭлемента.Вставить("children", Новый Массив);

                Результат.Добавить(ОписаниеЭлемента);
            Исключение
            КонецПопытки;
        КонецЦикла;
    Исключение
    КонецПопытки;

    Возврат Результат;

КонецФункции


Функция ПреобразоватьПлоскийСписокВДерево(ПлоскиеЭлементы)

    КорневыеЭлементы = Новый Массив;
    ИндексПоПути = Новый Соответствие;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        ИндексПоПути.Вставить(ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "path"), ОписаниеЭлемента);
    КонецЦикла;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        ПутьРодителя = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "parentPath");
        Если Не ЭтоПустаяСтрока(ПутьРодителя) И ИндексСодержитКлюч(ИндексПоПути, ПутьРодителя) Тогда
            Родитель = ИндексПоПути.Получить(ПутьРодителя);
            ДетиРодителя = ПолучитьПараметр(Родитель, "children");
            ДетиРодителя.Добавить(ОписаниеЭлемента);
        Иначе
            КорневыеЭлементы.Добавить(ОписаниеЭлемента);
        КонецЕсли;
    КонецЦикла;

    Возврат КорневыеЭлементы;

КонецФункции


Функция СобратьАтрибутыФормы(Форма, ПлоскиеЭлементы)

    Атрибуты = Новый Массив;
    ИндексПоПути = Новый Соответствие;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        ПутьКДанным = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "boundAttributePath");
        Если ЭтоПустаяСтрока(ПутьКДанным) Тогда
            Продолжить;
        КонецЕсли;

        Если Не ИндексСодержитКлюч(ИндексПоПути, ПутьКДанным) Тогда
            Значение = ПолучитьЗначениеПоПутиФормы(Форма, ПутьКДанным);

            ОписаниеАтрибута = Новый Структура;
            ОписаниеАтрибута.Вставить("path", ПутьКДанным);
            ОписаниеАтрибута.Вставить("name", ПоследнийСегментПути(ПутьКДанным));
            ОписаниеАтрибута.Вставить("title", ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "title"));
            ОписаниеАтрибута.Вставить("synonym", ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "synonym"));
            ОписаниеАтрибута.Вставить("type", ТипЗначенияВСтроку(Значение));
            ОписаниеАтрибута.Вставить("valuePreview", ПредставлениеЗначения(Значение));
            ОписаниеАтрибута.Вставить("visible", ПолучитьПараметр(ОписаниеЭлемента, "visible"));
            ОписаниеАтрибута.Вставить("available", ПолучитьПараметр(ОписаниеЭлемента, "available"));
            ОписаниеАтрибута.Вставить("readOnly", ПолучитьПараметр(ОписаниеЭлемента, "readOnly"));
            ОписаниеАтрибута.Вставить("required", Неопределено);
            ОписаниеАтрибута.Вставить("metadataPath", "");

            ИндексПоПути.Вставить(ПутьКДанным, ОписаниеАтрибута);
            Атрибуты.Добавить(ОписаниеАтрибута);
        КонецЕсли;
    КонецЦикла;

    ДополнительныеРеквизиты = ПолучитьРеквизитыФормы(Форма);
    Для Каждого РеквизитФормы Из ДополнительныеРеквизиты Цикл
        Попытка
            ИмяРеквизита = ПерваяЗаполненнаяСтрока(
                ЗначениеВСтроку(ПолучитьИмяРеквизитаФормы(РеквизитФормы)),
                ЗначениеВСтроку(РеквизитФормы)
            );

            Если ЭтоПустаяСтрока(ИмяРеквизита) Тогда
                Продолжить;
            КонецЕсли;

            Если Не ИндексСодержитКлюч(ИндексПоПути, ИмяРеквизита) Тогда
                Значение = ПолучитьЗначениеПоПутиФормы(Форма, ИмяРеквизита);

                ОписаниеАтрибута = Новый Структура;
                ОписаниеАтрибута.Вставить("path", ИмяРеквизита);
                ОписаниеАтрибута.Вставить("name", ИмяРеквизита);
                ОписаниеАтрибута.Вставить("title", ЗначениеВСтроку(ПолучитьЗаголовокРеквизитаФормы(РеквизитФормы)));
                ОписаниеАтрибута.Вставить("synonym", ЗначениеВСтроку(ПолучитьЗаголовокРеквизитаФормы(РеквизитФормы)));
                ОписаниеАтрибута.Вставить("type", ПерваяЗаполненнаяСтрока(
                    ЗначениеВСтроку(ПолучитьТипРеквизитаФормы(РеквизитФормы)),
                    ТипЗначенияВСтроку(Значение)
                ));
                ОписаниеАтрибута.Вставить("valuePreview", ПредставлениеЗначения(Значение));
                ОписаниеАтрибута.Вставить("visible", Неопределено);
                ОписаниеАтрибута.Вставить("available", Неопределено);
                ОписаниеАтрибута.Вставить("readOnly", Неопределено);
                ОписаниеАтрибута.Вставить("required", Неопределено);
                ОписаниеАтрибута.Вставить("metadataPath", "");

                ИндексПоПути.Вставить(ИмяРеквизита, ОписаниеАтрибута);
                Атрибуты.Добавить(ОписаниеАтрибута);
            КонецЕсли;
        Исключение
        КонецПопытки;
    КонецЦикла;

    Возврат Атрибуты;

КонецФункции


Функция СобратьТабличныеИсточникиФормы(Форма, ПлоскиеЭлементы, АтрибутыФормы = Неопределено)

    ТабличныеИсточники = Новый Массив;
    ИндексИсточников = Новый Соответствие;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        ПутьЭлемента = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "path");
        ПутьКДанным = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "boundAttributePath");
        ИмяЭлемента = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "name");
        ЗаголовокЭлемента = ПерваяЗаполненнаяСтрока(
            ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "title"),
            ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "synonym"),
            ИмяЭлемента
        );

        КолонкиПодсказки = ОбъединитьПодсказкиКолонок(
            ПолучитьПараметр(ОписаниеЭлемента, "tableColumnHints"),
            ПолучитьПодсказкиКолонокТаблицыИзПлоскогоСписка(ПлоскиеЭлементы, ПутьЭлемента, ИмяЭлемента)
        );

        ТабличныеДанные = ПолучитьПараметр(ОписаниеЭлемента, "tableData");
        Если ТабличныеДанные = Неопределено Тогда
            КандидатыПутей = ПолучитьКандидатыПутейТаблицыИзОписанияЭлемента(ОписаниеЭлемента);
            ТабличныеДанные = ПолучитьТабличныеДанныеПоКандидатамПути(Форма, КандидатыПутей, КолонкиПодсказки);
        КонецЕсли;
        ТабличныеДанные = ПрименитьПодсказкиКолонокКТабличнымДанным(ТабличныеДанные, КолонкиПодсказки);

        ДобавитьТабличныйИсточникВКоллекцию(
            ТабличныеИсточники,
            ИндексИсточников,
            ПутьКДанным,
            ПутьЭлемента,
            ИмяЭлемента,
            ЗаголовокЭлемента,
            ТабличныеДанные
        );
    КонецЦикла;

    Если АтрибутыФормы = Неопределено Тогда
        АтрибутыФормы = СобратьАтрибутыФормы(Форма, ПлоскиеЭлементы);
    КонецЕсли;

    Для Каждого ОписаниеАтрибута Из АтрибутыФормы Цикл
        ПутьАтрибута = ПолучитьСтрокуИзСтруктуры(ОписаниеАтрибута, "path");
        Если ЭтоПустаяСтрока(ПутьАтрибута) Тогда
            Продолжить;
        КонецЕсли;

        КандидатыПутей = Новый Массив;
        КандидатыПутей.Добавить(ПутьАтрибута);

        НормализованныйПуть = НормализоватьПутьДляОбъекта(ПутьАтрибута);
        Если Не ЭтоПустаяСтрока(НормализованныйПуть) Тогда
            КандидатыПутей.Добавить(НормализованныйПуть);
            КандидатыПутей.Добавить("Object." + НормализованныйПуть);
            КандидатыПутей.Добавить("Объект." + НормализованныйПуть);
        КонецЕсли;

        КолонкиПодсказки = ПолучитьПодсказкиКолонокТаблицыПоПутиДанных(ПлоскиеЭлементы, ПутьАтрибута, ПолучитьСтрокуИзСтруктуры(ОписаниеАтрибута, "name"));
        ТабличныеДанные = ПолучитьТабличныеДанныеПоКандидатамПути(Форма, УникализироватьСтроковыйМассив(КандидатыПутей), КолонкиПодсказки);
        ТабличныеДанные = ПрименитьПодсказкиКолонокКТабличнымДанным(ТабличныеДанные, КолонкиПодсказки);

        ИмяАтрибута = ПолучитьСтрокуИзСтруктуры(ОписаниеАтрибута, "name");
        ЗаголовокАтрибута = ПерваяЗаполненнаяСтрока(
            ПолучитьСтрокуИзСтруктуры(ОписаниеАтрибута, "title"),
            ПолучитьСтрокуИзСтруктуры(ОписаниеАтрибута, "synonym"),
            ИмяАтрибута
        );

        ДобавитьТабличныйИсточникВКоллекцию(
            ТабличныеИсточники,
            ИндексИсточников,
            ПутьАтрибута,
            "",
            ИмяАтрибута,
            ЗаголовокАтрибута,
            ТабличныеДанные
        );
    КонецЦикла;

    ГлобальныеКандидатыПутей = Новый Массив;
    ГлобальныеКандидатыПутей.Добавить("Список");
    ГлобальныеКандидатыПутей.Добавить("List");
    ГлобальныеКандидатыПутей.Добавить("ДинамическийСписок");
    ГлобальныеКандидатыПутей.Добавить("DynamicList");
    ГлобальныеКандидатыПутей.Добавить("Таблица");
    ГлобальныеКандидатыПутей.Добавить("Table");
    ГлобальныеКандидатыПутей.Добавить("Object.Список");
    ГлобальныеКандидатыПутей.Добавить("Object.List");
    ГлобальныеКандидатыПутей.Добавить("Object.ДинамическийСписок");
    ГлобальныеКандидатыПутей.Добавить("Object.DynamicList");
    ГлобальныеКандидатыПутей.Добавить("Object.Таблица");
    ГлобальныеКандидатыПутей.Добавить("Object.Table");
    ГлобальныеКандидатыПутей.Добавить("Объект.Список");
    ГлобальныеКандидатыПутей.Добавить("Объект.ДинамическийСписок");
    ГлобальныеКандидатыПутей.Добавить("Объект.Таблица");

    ТабличныеДанные = ПолучитьТабличныеДанныеПоКандидатамПути(Форма, УникализироватьСтроковыйМассив(ГлобальныеКандидатыПутей));
    ДобавитьТабличныйИсточникВКоллекцию(
        ТабличныеИсточники,
        ИндексИсточников,
        "",
        "",
        "FormTable",
        "Form table",
        ТабличныеДанные
    );

    Возврат ТабличныеИсточники;

КонецФункции


Процедура ДобавитьТабличныйИсточникВКоллекцию(Коллекция, Индекс, ПутьКДанным, ПутьЭлемента, Имя, Заголовок, ТабличныеДанные)

    Если ТабличныеДанные = Неопределено Тогда
        Возврат;
    КонецЕсли;

    ПутьИсточника = ЗначениеВСтроку(ПолучитьЗначениеСвойства(ТабличныеДанные, "sourcePath"));
    КлючИсточника = ПостроитьКлючТабличногоИсточника(ПутьКДанным, ПутьЭлемента, ПутьИсточника);
    Если ЭтоПустаяСтрока(КлючИсточника) Тогда
        КлючИсточника = "Table" + ЗначениеВСтроку(Коллекция.Количество() + 1);
    КонецЕсли;

    Если ИндексСодержитКлюч(Индекс, КлючИсточника) Тогда
        Возврат;
    КонецЕсли;
    Индекс.Вставить(КлючИсточника, Истина);

    ОписаниеИсточника = Новый Структура;

    Если Не ЭтоПустаяСтрока(ПутьКДанным) Тогда
        ОписаниеИсточника.Вставить("path", ПутьКДанным);
        ОписаниеИсточника.Вставить("boundAttributePath", ПутьКДанным);
    КонецЕсли;
    Если Не ЭтоПустаяСтрока(ПутьЭлемента) Тогда
        ОписаниеИсточника.Вставить("elementPath", ПутьЭлемента);
    КонецЕсли;
    Если Не ЭтоПустаяСтрока(Имя) Тогда
        ОписаниеИсточника.Вставить("name", Имя);
    КонецЕсли;
    Если Не ЭтоПустаяСтрока(Заголовок) Тогда
        ОписаниеИсточника.Вставить("title", Заголовок);
    КонецЕсли;
    Если Не ЭтоПустаяСтрока(ПутьИсточника) Тогда
        ОписаниеИсточника.Вставить("sourcePath", ПутьИсточника);
    КонецЕсли;

    ОписаниеИсточника.Вставить("tableData", ТабличныеДанные);
    Коллекция.Добавить(ОписаниеИсточника);

КонецПроцедуры


Функция ПолучитьТабличныеДанныеПоКандидатамПути(Форма, КандидатыПутей, КолонкиПодсказки = Неопределено)

    Если КандидатыПутей = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    Для Каждого КандидатПути Из КандидатыПутей Цикл
        Если ЭтоПустаяСтрока(КандидатПути) Тогда
            Продолжить;
        КонецЕсли;

        Значение = ПолучитьЗначениеПоПутиФормы(Форма, КандидатПути);
        ТабличныеДанные = ПопытатьсяСериализоватьТабличныеДанные(Значение, КолонкиПодсказки);
        Если ТабличныеДанные <> Неопределено Тогда
            ТабличныеДанные.Вставить("sourcePath", КандидатПути);
            Возврат ТабличныеДанные;
        КонецЕсли;
    КонецЦикла;

    Возврат Неопределено;

КонецФункции


Функция ОбъединитьПодсказкиКолонок(ОсновныеПодсказки, ДополнительныеПодсказки = Неопределено)

    Результат = Новый Массив;

    Если ОсновныеПодсказки <> Неопределено Тогда
        Для Каждого Подсказка Из ОсновныеПодсказки Цикл
            Результат.Добавить(Подсказка);
        КонецЦикла;
    КонецЕсли;

    Если ДополнительныеПодсказки <> Неопределено Тогда
        Для Каждого Подсказка Из ДополнительныеПодсказки Цикл
            Результат.Добавить(Подсказка);
        КонецЦикла;
    КонецЕсли;

    Возврат Результат;

КонецФункции


Функция ПолучитьПодсказкиКолонокТаблицыИзЭлемента(ЭлементТаблицы, ИмяТаблицы = "")

    ПодсказкиКолонок = Новый Массив;
    Если ЭлементТаблицы = Неопределено Тогда
        Возврат ПодсказкиКолонок;
    КонецЕсли;

    КолонкиЭлемента = ПолучитьЗначениеСвойства(ЭлементТаблицы, "Колонки");
    Если КолонкиЭлемента = Неопределено Тогда
        КолонкиЭлемента = ПолучитьЗначениеСвойства(ЭлементТаблицы, "Columns");
    КонецЕсли;
    Если КолонкиЭлемента = Неопределено Тогда
        Возврат ПодсказкиКолонок;
    КонецЕсли;

    Попытка
        Для Каждого КолонкаЭлемента Из КолонкиЭлемента Цикл
            ВидимостьКолонки = ПолучитьЗначениеСвойства(КолонкаЭлемента, "Видимость");
            Если ВидимостьКолонки = Неопределено Тогда
                ВидимостьКолонки = ПолучитьЗначениеСвойства(КолонкаЭлемента, "Visible");
            КонецЕсли;
            Если ВидимостьКолонки = Ложь Тогда
                Продолжить;
            КонецЕсли;

            ИмяКолонки = ПерваяЗаполненнаяСтрока(
                ЗначениеВСтроку(ПолучитьЗначениеСвойства(КолонкаЭлемента, "Имя")),
                ЗначениеВСтроку(ПолучитьЗначениеСвойства(КолонкаЭлемента, "Name"))
            );
            ЗаголовокКолонки = ПерваяЗаполненнаяСтрока(
                ЗначениеВСтроку(ПолучитьЗначениеСвойства(КолонкаЭлемента, "Заголовок")),
                ЗначениеВСтроку(ПолучитьЗначениеСвойства(КолонкаЭлемента, "Title")),
                ПерваяЗаполненнаяСтрока(
                    ЗначениеВСтроку(ПолучитьЗначениеСвойства(КолонкаЭлемента, "Подсказка")),
                    ЗначениеВСтроку(ПолучитьЗначениеСвойства(КолонкаЭлемента, "Tooltip")),
                    ИмяКолонки
                )
            );

            КлючиКолонки = Новый Массив;
            ПутьДанныхКолонки = ПерваяЗаполненнаяСтрока(
                ЗначениеВСтроку(ПолучитьЗначениеСвойства(КолонкаЭлемента, "ПутьКДанным")),
                ЗначениеВСтроку(ПолучитьЗначениеСвойства(КолонкаЭлемента, "DataPath")),
                ПерваяЗаполненнаяСтрока(
                    ЗначениеВСтроку(ПолучитьЗначениеСвойства(КолонкаЭлемента, "Данные")),
                    ЗначениеВСтроку(ПолучитьЗначениеСвойства(КолонкаЭлемента, "Data"))
                )
            );
            ДобавитьКлючКолонкиПодсказки(КлючиКолонки, ПоследнийСегментПути(ПутьДанныхКолонки));
            ДобавитьКлючКолонкиПодсказки(КлючиКолонки, ИмяКолонки);

            Если Не ЭтоПустаяСтрока(ИмяКолонки) И Не ЭтоПустаяСтрока(ИмяТаблицы)
                И Лев(ИмяКолонки, СтрДлина(ИмяТаблицы)) = ИмяТаблицы Тогда
                КлючБезПрефикса = Сред(ИмяКолонки, СтрДлина(ИмяТаблицы) + 1);
                ДобавитьКлючКолонкиПодсказки(КлючиКолонки, КлючБезПрефикса);
            КонецЕсли;

            Если КлючиКолонки.Количество() = 0 Тогда
                Продолжить;
            КонецЕсли;

            ПодсказкаКолонки = Новый Структура;
            ПодсказкаКолонки.Вставить("title", ЗаголовокКолонки);
            ПодсказкаКолонки.Вставить("keys", УникализироватьСтроковыйМассив(КлючиКолонки));
            ПодсказкиКолонок.Добавить(ПодсказкаКолонки);
        КонецЦикла;
    Исключение
    КонецПопытки;

    Возврат ПодсказкиКолонок;

КонецФункции


Функция ПолучитьПодсказкиКолонокТаблицыИзПлоскогоСписка(ПлоскиеЭлементы, ПутьТаблицы, ИмяТаблицы = "")

    ПодсказкиКолонок = Новый Массив;
    Если ПлоскиеЭлементы = Неопределено Или ЭтоПустаяСтрока(ПутьТаблицы) Тогда
        Возврат ПодсказкиКолонок;
    КонецЕсли;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        ПутьРодителя = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "parentPath");
        Если ПутьРодителя <> ПутьТаблицы Тогда
            Продолжить;
        КонецЕсли;

        ВидимостьКолонки = ПолучитьПараметр(ОписаниеЭлемента, "visible");
        Если ВидимостьКолонки = Ложь Тогда
            Продолжить;
        КонецЕсли;

        ВидЭлемента = НРег(ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "kind"));
        ТипЭлемента = НРег(ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "type"));
        ЭтоПоле = СтрНайти(ВидЭлемента, "field") > 0
            Или СтрНайти(ВидЭлемента, "поле") > 0
            Или СтрНайти(ТипЭлемента, "field") > 0
            Или СтрНайти(ТипЭлемента, "поле") > 0;
        Если Не ЭтоПоле Тогда
            Продолжить;
        КонецЕсли;

        ИмяКолонки = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "name");
        ЗаголовокКолонки = ПерваяЗаполненнаяСтрока(
            ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "title"),
            ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "synonym"),
            ИмяКолонки
        );

        КлючиКолонки = Новый Массив;
        ПутьДанныхКолонки = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "boundAttributePath");
        ДобавитьКлючКолонкиПодсказки(КлючиКолонки, ПоследнийСегментПути(ПутьДанныхКолонки));
        ДобавитьКлючКолонкиПодсказки(КлючиКолонки, ИмяКолонки);

        Если Не ЭтоПустаяСтрока(ИмяКолонки) И Не ЭтоПустаяСтрока(ИмяТаблицы)
            И Лев(ИмяКолонки, СтрДлина(ИмяТаблицы)) = ИмяТаблицы Тогда
            КлючБезПрефикса = Сред(ИмяКолонки, СтрДлина(ИмяТаблицы) + 1);
            ДобавитьКлючКолонкиПодсказки(КлючиКолонки, КлючБезПрефикса);
        КонецЕсли;

        Если КлючиКолонки.Количество() = 0 Тогда
            Продолжить;
        КонецЕсли;

        ПодсказкаКолонки = Новый Структура;
        ПодсказкаКолонки.Вставить("title", ЗаголовокКолонки);
        ПодсказкаКолонки.Вставить("keys", УникализироватьСтроковыйМассив(КлючиКолонки));
        ПодсказкиКолонок.Добавить(ПодсказкаКолонки);
    КонецЦикла;

    Возврат ПодсказкиКолонок;

КонецФункции


Функция ПолучитьПодсказкиКолонокТаблицыПоПутиДанных(ПлоскиеЭлементы, ПутьКДанным, ИмяТаблицы = "")

    Если ПлоскиеЭлементы = Неопределено Или ЭтоПустаяСтрока(ПутьКДанным) Тогда
        Возврат Новый Массив;
    КонецЕсли;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        Если ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "boundAttributePath") <> ПутьКДанным Тогда
            Продолжить;
        КонецЕсли;

        ПутьТаблицы = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "path");
        Если ЭтоПустаяСтрока(ПутьТаблицы) Тогда
            Продолжить;
        КонецЕсли;

        Возврат ОбъединитьПодсказкиКолонок(
            ПолучитьПараметр(ОписаниеЭлемента, "tableColumnHints"),
            ПолучитьПодсказкиКолонокТаблицыИзПлоскогоСписка(ПлоскиеЭлементы, ПутьТаблицы, ИмяТаблицы)
        );
    КонецЦикла;

    Возврат Новый Массив;

КонецФункции


Функция ПрименитьПодсказкиКолонокКТабличнымДанным(ТабличныеДанные, КолонкиПодсказки)

    Если ТабличныеДанные = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    НормализованныеПодсказки = НормализоватьПодсказкиКолонок(КолонкиПодсказки);
    Если НормализованныеПодсказки.Количество() = 0 Тогда
        Возврат ТабличныеДанные;
    КонецЕсли;

    ИсходныеКолонки = ПолучитьПараметр(ТабличныеДанные, "columns");
    ИсходныеСтроки = ПолучитьПараметр(ТабличныеДанные, "rows");
    Если ИсходныеКолонки = Неопределено Или ИсходныеСтроки = Неопределено Тогда
        Возврат ТабличныеДанные;
    КонецЕсли;

    ИндексыКолонок = Новый Массив;
    НовыеКолонки = Новый Массив;
    ИспользованныеИндексы = Новый Соответствие;

    Для Каждого ПодсказкаКолонки Из НормализованныеПодсказки Цикл
        КлючиКолонки = ПолучитьПараметр(ПодсказкаКолонки, "keys");
        ИндексКолонки = НайтиИндексКолонкиПоКлючам(ИсходныеКолонки, КлючиКолонки);
        Если ИндексКолонки < 0 Тогда
            Продолжить;
        КонецЕсли;

        КлючИндекса = ЗначениеВСтроку(ИндексКолонки);
        Если ИндексСодержитКлюч(ИспользованныеИндексы, КлючИндекса) Тогда
            Продолжить;
        КонецЕсли;
        ИспользованныеИндексы.Вставить(КлючИндекса, Истина);

        ЗаголовокКолонки = ПерваяЗаполненнаяСтрока(
            ПолучитьСтрокуИзСтруктуры(ПодсказкаКолонки, "title"),
            ЗначениеВСтроку(ИсходныеКолонки[ИндексКолонки]),
            "Column" + ЗначениеВСтроку(НовыеКолонки.Количество() + 1)
        );
        НовыеКолонки.Добавить(ЗаголовокКолонки);
        ИндексыКолонок.Добавить(ИндексКолонки);
    КонецЦикла;

    Если НовыеКолонки.Количество() = 0 Тогда
        Возврат ТабличныеДанные;
    КонецЕсли;

    НовыеСтроки = Новый Массив;
    Для Каждого ИсходнаяСтрока Из ИсходныеСтроки Цикл
        НоваяСтрока = Новый Массив;
        Для Каждого ИндексКолонки Из ИндексыКолонок Цикл
            ЗначениеЯчейки = "";
            Попытка
                ЗначениеЯчейки = ЗначениеВСтроку(ИсходнаяСтрока[ИндексКолонки]);
            Исключение
            КонецПопытки;

            НоваяСтрока.Добавить(ЗначениеЯчейки);
        КонецЦикла;
        НовыеСтроки.Добавить(НоваяСтрока);
    КонецЦикла;

    ТабличныеДанные.Вставить("columns", НовыеКолонки);
    ТабличныеДанные.Вставить("rows", НовыеСтроки);

    Возврат ТабличныеДанные;

КонецФункции


Функция НайтиИндексКолонкиПоКлючам(Колонки, КлючиКолонки)

    Если Колонки = Неопределено Или КлючиКолонки = Неопределено Тогда
        Возврат -1;
    КонецЕсли;

    Для Каждого КлючКолонки Из КлючиКолонки Цикл
        ИндексКолонки = НайтиИндексКолонки(Колонки, КлючКолонки);
        Если ИндексКолонки >= 0 Тогда
            Возврат ИндексКолонки;
        КонецЕсли;
    КонецЦикла;

    Возврат -1;

КонецФункции


Функция НайтиИндексКолонки(Колонки, ИскомыйКлюч)

    Ключ = ЗначениеВСтроку(ИскомыйКлюч);
    Если ЭтоПустаяСтрока(Ключ) Тогда
        Возврат -1;
    КонецЕсли;

    НормализованныйКлюч = НРег(Ключ);
    ПоследнийСегментКлюча = НРег(ПоследнийСегментПути(Ключ));

    Для ИндексКолонки = 0 По Колонки.Количество() - 1 Цикл
        ИмяКолонки = ЗначениеВСтроку(Колонки[ИндексКолонки]);
        Если ИмяКолонки = Ключ Тогда
            Возврат ИндексКолонки;
        КонецЕсли;

        НормализованноеИмя = НРег(ИмяКолонки);
        Если НормализованноеИмя = НормализованныйКлюч Тогда
            Возврат ИндексКолонки;
        КонецЕсли;

        Если НРег(ПоследнийСегментПути(ИмяКолонки)) = НормализованныйКлюч Тогда
            Возврат ИндексКолонки;
        КонецЕсли;

        Если Не ЭтоПустаяСтрока(ПоследнийСегментКлюча) И НРег(ПоследнийСегментПути(ИмяКолонки)) = ПоследнийСегментКлюча Тогда
            Возврат ИндексКолонки;
        КонецЕсли;
    КонецЦикла;

    Возврат -1;

КонецФункции


Процедура ДобавитьКлючКолонкиПодсказки(КлючиКолонки, ЗначениеКлюча)

    Ключ = ЗначениеВСтроку(ЗначениеКлюча);
    Если ЭтоПустаяСтрока(Ключ) Тогда
        Возврат;
    КонецЕсли;

    КлючиКолонки.Добавить(Ключ);

КонецПроцедуры


Функция ПолучитьКандидатыПутейТаблицыИзОписанияЭлемента(ОписаниеЭлемента)

    Кандидаты = Новый Массив;

    ПутьКДанным = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "boundAttributePath");
    Если Не ЭтоПустаяСтрока(ПутьКДанным) Тогда
        Кандидаты.Добавить(ПутьКДанным);
        НормализованныйПуть = НормализоватьПутьДляОбъекта(ПутьКДанным);
        Если Не ЭтоПустаяСтрока(НормализованныйПуть) Тогда
            Кандидаты.Добавить(НормализованныйПуть);
            Кандидаты.Добавить("Object." + НормализованныйПуть);
            Кандидаты.Добавить("Объект." + НормализованныйПуть);
        КонецЕсли;
    КонецЕсли;

    ИмяЭлемента = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "name");
    Если Не ЭтоПустаяСтрока(ИмяЭлемента) Тогда
        Кандидаты.Добавить("Object." + ИмяЭлемента);
        Кандидаты.Добавить("Объект." + ИмяЭлемента);
        Кандидаты.Добавить("ThisObject." + ИмяЭлемента);
        Кандидаты.Добавить(ИмяЭлемента);
    КонецЕсли;

    ПутьЭлемента = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "path");
    ПоследнийСегмент = ПоследнийСегментПути(ПутьЭлемента);
    Если Не ЭтоПустаяСтрока(ПоследнийСегмент) Тогда
        Кандидаты.Добавить("Object." + ПоследнийСегмент);
        Кандидаты.Добавить("Объект." + ПоследнийСегмент);
        Кандидаты.Добавить(ПоследнийСегмент);
    КонецЕсли;

    Возврат УникализироватьСтроковыйМассив(Кандидаты);

КонецФункции


Функция ПостроитьКлючТабличногоИсточника(ПутьКДанным, ПутьЭлемента, ПутьИсточника)

    Возврат ПерваяЗаполненнаяСтрока(ПутьКДанным, ПутьЭлемента, ПутьИсточника);

КонецФункции


Функция СобратьКомандыФормы(Форма)

    КомандыФормы = Новый Массив;
    КоллекцияКоманд = ПолучитьКомандыФормыКоллекция(Форма);

    Если КоллекцияКоманд = Неопределено Тогда
        Возврат КомандыФормы;
    КонецЕсли;

    Попытка
        Для Каждого КомандаФормы Из КоллекцияКоманд Цикл
            ОписаниеКоманды = Новый Структура;
            ОписаниеКоманды.Вставить("name", ПерваяЗаполненнаяСтрока(
                ЗначениеВСтроку(ПолучитьИмяКоманды(КомандаФормы))
            ));
            ОписаниеКоманды.Вставить("title", ПерваяЗаполненнаяСтрока(
                ЗначениеВСтроку(ПолучитьЗаголовокКоманды(КомандаФормы)),
                ЗначениеВСтроку(ПолучитьПодсказкуКоманды(КомандаФормы))
            ));
            ОписаниеКоманды.Вставить("available", ПолучитьДоступностьКоманды(КомандаФормы));
            ОписаниеКоманды.Вставить("action", Строка(ТипЗнч(КомандаФормы)));
            КомандыФормы.Добавить(ОписаниеКоманды);
        КонецЦикла;
    Исключение
    КонецПопытки;

    Возврат КомандыФормы;

КонецФункции


Функция ПолучитьПутьЭлемента(Элемент)

    Если Элемент = Неопределено Тогда
        Возврат "";
    КонецЕсли;

    ИмяЭлемента = ПерваяЗаполненнаяСтрока(
        ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент)),
        Строка(ТипЗнч(Элемент))
    );

    Родитель = ПолучитьРодителяЭлемента(Элемент);
    Если Родитель = Неопределено Тогда
        Возврат ИмяЭлемента;
    КонецЕсли;

    ПутьРодителя = ПолучитьПутьЭлемента(Родитель);
    Если ЭтоПустаяСтрока(ПутьРодителя) Тогда
        Возврат ИмяЭлемента;
    КонецЕсли;

    Возврат ПутьРодителя + "." + ИмяЭлемента;

КонецФункции


Функция ПолучитьПутьДанныхЭлемента(Элемент)

    Попытка
        Если Не ЭтоПустаяСтрока(Элемент.ПутьКДанным) Тогда
            Возврат ЗначениеВСтроку(Элемент.ПутьКДанным);
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Возврат ЗначениеВСтроку(Элемент.Данные);
    Исключение
    КонецПопытки;

    Возврат "";

КонецФункции


Функция ПолучитьЗначениеПоПутиФормы(Форма, ПутьКДанным)

    Если ЭтоПустаяСтрока(ПутьКДанным) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Попытка
        Возврат Форма[ПутьКДанным];
    Исключение
    КонецПопытки;

    Возврат ПолучитьЗначениеПоПутиОбъекта(Форма, ПутьКДанным);

КонецФункции


Функция ПолучитьЗначениеПоПутиОбъекта(БазовыйОбъект, ПутьКДанным)

    Если БазовыйОбъект = Неопределено Или ЭтоПустаяСтрока(ПутьКДанным) Тогда
        Возврат Неопределено;
    КонецЕсли;

    ТекущееЗначение = БазовыйОбъект;
    ЧастиПути = СтрРазделить(ПутьКДанным, ".");

    Для Каждого СегментПути Из ЧастиПути Цикл
        Если ЭтоПустаяСтрока(СегментПути) Тогда
            Продолжить;
        КонецЕсли;

        Если ТекущееЗначение = Неопределено Тогда
            Возврат Неопределено;
        КонецЕсли;

        Попытка
            ТекущееЗначение = ТекущееЗначение[СегментПути];
        Исключение
            Попытка
                ТекущееЗначение = Вычислить("ТекущееЗначение." + СегментПути);
            Исключение
                Возврат Неопределено;
            КонецПопытки;
        КонецПопытки;
    КонецЦикла;

    Возврат ТекущееЗначение;

КонецФункции


Функция НормализоватьПутьДляОбъекта(ПутьКДанным)

    Если ЭтоПустаяСтрока(ПутьКДанным) Тогда
        Возврат "";
    КонецЕсли;

    Если Лев(ПутьКДанным, 7) = "Object." Тогда
        Возврат Сред(ПутьКДанным, 8);
    КонецЕсли;

    Если Лев(ПутьКДанным, 7) = "Объект." Тогда
        Возврат Сред(ПутьКДанным, 8);
    КонецЕсли;

    Если Лев(ПутьКДанным, 11) = "ThisObject." Тогда
        Возврат Сред(ПутьКДанным, 12);
    КонецЕсли;

    Возврат ПутьКДанным;

КонецФункции


