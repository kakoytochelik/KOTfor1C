Функция СобратьОписаниеФормы(Форма, МетаданныеФормы, ПлоскиеЭлементы, ЗаголовокОкна = "")

    Описание = Новый Структура;
    ИтоговыйЗаголовок = ПерваяЗаполненнаяСтрока(
        ЗаголовокОкна,
        ЗначениеВСтроку(ПолучитьЗаголовокФормы(Форма))
    );
    Описание.Вставить("title", ИтоговыйЗаголовок);
    Описание.Вставить("windowTitle", ИтоговыйЗаголовок);
    Описание.Вставить("name", ЗначениеВСтроку(ПолучитьИмяФормыДляСнимка(Форма)));
    Описание.Вставить("metadataPath", МетаданныеФормы);
    Описание.Вставить("type", Строка(ТипЗнч(Форма)));
    Описание.Вставить("viewKind", "");
    Описание.Вставить("activeElementPath", ПолучитьПутьАктивногоЭлемента(Форма, ПлоскиеЭлементы));
    Описание.Вставить("notes", Новый Массив);

    Возврат Описание;

КонецФункции


Функция ПолучитьПутьАктивногоЭлемента(Форма, ПлоскиеЭлементы)

    ТекущийЭлемент = ПолучитьТекущийЭлементФормы(Форма);
    Если ТекущийЭлемент <> Неопределено Тогда
        Возврат ПолучитьПутьЭлемента(ТекущийЭлемент);
    КонецЕсли;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        Если ПолучитьБулевоИзСтруктуры(ОписаниеЭлемента, "active", Ложь) Тогда
            Возврат ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "path");
        КонецЕсли;
    КонецЦикла;

    Возврат "";

КонецФункции


Функция СобратьПлоскийСписокЭлементов(Форма)

    Результат = Новый Массив;
    КоллекцияЭлементов = ПолучитьЭлементыФормы(Форма);

    Если КоллекцияЭлементов = Неопределено Тогда
        Возврат Результат;
    КонецЕсли;

    АктивныйПуть = ПолучитьПутьЭлемента(ПолучитьТекущийЭлементФормы(Форма));

    Попытка
        Для Каждого Элемент Из КоллекцияЭлементов Цикл
            Попытка
                ОписаниеЭлемента = Новый Структура;
                ПутьЭлемента = ПолучитьПутьЭлемента(Элемент);
                ПутьРодителя = ПолучитьПутьЭлемента(ПолучитьРодителяЭлемента(Элемент));
                ПутьКДанным = ПолучитьПутьДанныхЭлемента(Элемент);
                ПутьКДанным = ОпределитьПутьДанныхЭлемента(Форма, Элемент, ПутьКДанным);

                ОписаниеЭлемента.Вставить("path", ПутьЭлемента);
                ОписаниеЭлемента.Вставить("parentPath", ПутьРодителя);
                ОписаниеЭлемента.Вставить("name", ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент)));
                ОписаниеЭлемента.Вставить("title", ПерваяЗаполненнаяСтрока(
                    ЗначениеВСтроку(ПолучитьЗаголовокЭлемента(Элемент)),
                    ЗначениеВСтроку(ПолучитьПодсказкуЭлемента(Элемент)),
                    ЗначениеВСтроку(ПолучитьПодсказкуВводаЭлемента(Элемент))
                ));
                ОписаниеЭлемента.Вставить("synonym", ПерваяЗаполненнаяСтрока(
                    ЗначениеВСтроку(ПолучитьЗаголовокЭлемента(Элемент)),
                    ЗначениеВСтроку(ПолучитьПодсказкуВводаЭлемента(Элемент))
                ));
                ОписаниеЭлемента.Вставить("toolTip", ЗначениеВСтроку(ПолучитьПодсказкуЭлемента(Элемент)));
                ОписаниеЭлемента.Вставить("inputHint", ЗначениеВСтроку(ПолучитьПодсказкуВводаЭлемента(Элемент)));
                ОписаниеЭлемента.Вставить("kind", ПерваяЗаполненнаяСтрока(
                    ЗначениеВСтроку(ПолучитьВидЭлемента(Элемент)),
                    Строка(ТипЗнч(Элемент))
                ));
                ОписаниеЭлемента.Вставить("type", Строка(ТипЗнч(Элемент)));
                ОписаниеЭлемента.Вставить("boundAttributePath", ПутьКДанным);
                ОписаниеЭлемента.Вставить("visible", ПолучитьВидимостьЭлемента(Элемент));
                ОписаниеЭлемента.Вставить("available", ПолучитьДоступностьЭлемента(Элемент));
                ОписаниеЭлемента.Вставить("enabled", ПолучитьДоступностьЭлемента(Элемент));
                ОписаниеЭлемента.Вставить("readOnly", ПолучитьТолькоПросмотрЭлемента(Элемент));
                ОписаниеЭлемента.Вставить("active", ПутьЭлемента = АктивныйПуть);
                ОписаниеЭлемента.Вставить("valuePreview", ПолучитьПредставлениеЗначенияЭлемента(Форма, Элемент, ПутьКДанным));
                ОписаниеЭлемента.Вставить("metadataPath", "");
                ОписаниеЭлемента.Вставить("children", Новый Массив);

                Результат.Добавить(ОписаниеЭлемента);
            Исключение
            КонецПопытки;
        КонецЦикла;
    Исключение
    КонецПопытки;

    Возврат Результат;

КонецФункции


Функция ПреобразоватьПлоскийСписокВДерево(ПлоскиеЭлементы)

    КорневыеЭлементы = Новый Массив;
    ИндексПоПути = Новый Соответствие;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        ИндексПоПути.Вставить(ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "path"), ОписаниеЭлемента);
    КонецЦикла;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        ПутьРодителя = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "parentPath");
        Если Не ЭтоПустаяСтрока(ПутьРодителя) И ИндексСодержитКлюч(ИндексПоПути, ПутьРодителя) Тогда
            Родитель = ИндексПоПути.Получить(ПутьРодителя);
            ДетиРодителя = ПолучитьПараметр(Родитель, "children");
            ДетиРодителя.Добавить(ОписаниеЭлемента);
        Иначе
            КорневыеЭлементы.Добавить(ОписаниеЭлемента);
        КонецЕсли;
    КонецЦикла;

    Возврат КорневыеЭлементы;

КонецФункции


Функция СобратьАтрибутыФормы(Форма, ПлоскиеЭлементы)

    Атрибуты = Новый Массив;
    ИндексПоПути = Новый Соответствие;

    Для Каждого ОписаниеЭлемента Из ПлоскиеЭлементы Цикл
        ПутьКДанным = ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "boundAttributePath");
        Если ЭтоПустаяСтрока(ПутьКДанным) Тогда
            Продолжить;
        КонецЕсли;

        Если Не ИндексСодержитКлюч(ИндексПоПути, ПутьКДанным) Тогда
            Значение = ПолучитьЗначениеПоПутиФормы(Форма, ПутьКДанным);

            ОписаниеАтрибута = Новый Структура;
            ОписаниеАтрибута.Вставить("path", ПутьКДанным);
            ОписаниеАтрибута.Вставить("name", ПоследнийСегментПути(ПутьКДанным));
            ОписаниеАтрибута.Вставить("title", ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "title"));
            ОписаниеАтрибута.Вставить("synonym", ПолучитьСтрокуИзСтруктуры(ОписаниеЭлемента, "synonym"));
            ОписаниеАтрибута.Вставить("type", ТипЗначенияВСтроку(Значение));
            ОписаниеАтрибута.Вставить("valuePreview", ПредставлениеЗначения(Значение));
            ОписаниеАтрибута.Вставить("visible", ПолучитьПараметр(ОписаниеЭлемента, "visible"));
            ОписаниеАтрибута.Вставить("available", ПолучитьПараметр(ОписаниеЭлемента, "available"));
            ОписаниеАтрибута.Вставить("readOnly", ПолучитьПараметр(ОписаниеЭлемента, "readOnly"));
            ОписаниеАтрибута.Вставить("required", Неопределено);
            ОписаниеАтрибута.Вставить("metadataPath", "");

            ИндексПоПути.Вставить(ПутьКДанным, ОписаниеАтрибута);
            Атрибуты.Добавить(ОписаниеАтрибута);
        КонецЕсли;
    КонецЦикла;

    ДополнительныеРеквизиты = ПолучитьРеквизитыФормы(Форма);
    Для Каждого РеквизитФормы Из ДополнительныеРеквизиты Цикл
        Попытка
            ИмяРеквизита = ПерваяЗаполненнаяСтрока(
                ЗначениеВСтроку(ПолучитьИмяРеквизитаФормы(РеквизитФормы)),
                ЗначениеВСтроку(РеквизитФормы)
            );

            Если ЭтоПустаяСтрока(ИмяРеквизита) Тогда
                Продолжить;
            КонецЕсли;

            Если Не ИндексСодержитКлюч(ИндексПоПути, ИмяРеквизита) Тогда
                Значение = ПолучитьЗначениеПоПутиФормы(Форма, ИмяРеквизита);

                ОписаниеАтрибута = Новый Структура;
                ОписаниеАтрибута.Вставить("path", ИмяРеквизита);
                ОписаниеАтрибута.Вставить("name", ИмяРеквизита);
                ОписаниеАтрибута.Вставить("title", ЗначениеВСтроку(ПолучитьЗаголовокРеквизитаФормы(РеквизитФормы)));
                ОписаниеАтрибута.Вставить("synonym", ЗначениеВСтроку(ПолучитьЗаголовокРеквизитаФормы(РеквизитФормы)));
                ОписаниеАтрибута.Вставить("type", ПерваяЗаполненнаяСтрока(
                    ЗначениеВСтроку(ПолучитьТипРеквизитаФормы(РеквизитФормы)),
                    ТипЗначенияВСтроку(Значение)
                ));
                ОписаниеАтрибута.Вставить("valuePreview", ПредставлениеЗначения(Значение));
                ОписаниеАтрибута.Вставить("visible", Неопределено);
                ОписаниеАтрибута.Вставить("available", Неопределено);
                ОписаниеАтрибута.Вставить("readOnly", Неопределено);
                ОписаниеАтрибута.Вставить("required", Неопределено);
                ОписаниеАтрибута.Вставить("metadataPath", "");

                ИндексПоПути.Вставить(ИмяРеквизита, ОписаниеАтрибута);
                Атрибуты.Добавить(ОписаниеАтрибута);
            КонецЕсли;
        Исключение
        КонецПопытки;
    КонецЦикла;

    Возврат Атрибуты;

КонецФункции


Функция СобратьКомандыФормы(Форма)

    КомандыФормы = Новый Массив;
    КоллекцияКоманд = ПолучитьКомандыФормыКоллекция(Форма);

    Если КоллекцияКоманд = Неопределено Тогда
        Возврат КомандыФормы;
    КонецЕсли;

    Попытка
        Для Каждого КомандаФормы Из КоллекцияКоманд Цикл
            ОписаниеКоманды = Новый Структура;
            ОписаниеКоманды.Вставить("name", ПерваяЗаполненнаяСтрока(
                ЗначениеВСтроку(ПолучитьИмяКоманды(КомандаФормы))
            ));
            ОписаниеКоманды.Вставить("title", ПерваяЗаполненнаяСтрока(
                ЗначениеВСтроку(ПолучитьЗаголовокКоманды(КомандаФормы)),
                ЗначениеВСтроку(ПолучитьПодсказкуКоманды(КомандаФормы))
            ));
            ОписаниеКоманды.Вставить("available", ПолучитьДоступностьКоманды(КомандаФормы));
            ОписаниеКоманды.Вставить("action", Строка(ТипЗнч(КомандаФормы)));
            КомандыФормы.Добавить(ОписаниеКоманды);
        КонецЦикла;
    Исключение
    КонецПопытки;

    Возврат КомандыФормы;

КонецФункции


Функция ПолучитьПутьЭлемента(Элемент)

    Если Элемент = Неопределено Тогда
        Возврат "";
    КонецЕсли;

    ИмяЭлемента = ПерваяЗаполненнаяСтрока(
        ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент)),
        Строка(ТипЗнч(Элемент))
    );

    Родитель = ПолучитьРодителяЭлемента(Элемент);
    Если Родитель = Неопределено Тогда
        Возврат ИмяЭлемента;
    КонецЕсли;

    ПутьРодителя = ПолучитьПутьЭлемента(Родитель);
    Если ЭтоПустаяСтрока(ПутьРодителя) Тогда
        Возврат ИмяЭлемента;
    КонецЕсли;

    Возврат ПутьРодителя + "." + ИмяЭлемента;

КонецФункции


Функция ПолучитьПутьДанныхЭлемента(Элемент)

    Попытка
        Если Не ЭтоПустаяСтрока(Элемент.ПутьКДанным) Тогда
            Возврат ЗначениеВСтроку(Элемент.ПутьКДанным);
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Возврат ЗначениеВСтроку(Элемент.Данные);
    Исключение
    КонецПопытки;

    Возврат "";

КонецФункции


Функция ПолучитьЗначениеПоПутиФормы(Форма, ПутьКДанным)

    Если ЭтоПустаяСтрока(ПутьКДанным) Тогда
        Возврат Неопределено;
    КонецЕсли;

    Попытка
        Возврат Форма[ПутьКДанным];
    Исключение
    КонецПопытки;

    Возврат ПолучитьЗначениеПоПутиОбъекта(Форма, ПутьКДанным);

КонецФункции


Функция ПолучитьЗначениеПоПутиОбъекта(БазовыйОбъект, ПутьКДанным)

    Если БазовыйОбъект = Неопределено Или ЭтоПустаяСтрока(ПутьКДанным) Тогда
        Возврат Неопределено;
    КонецЕсли;

    ТекущееЗначение = БазовыйОбъект;
    ЧастиПути = СтрРазделить(ПутьКДанным, ".");

    Для Каждого СегментПути Из ЧастиПути Цикл
        Если ЭтоПустаяСтрока(СегментПути) Тогда
            Продолжить;
        КонецЕсли;

        Если ТекущееЗначение = Неопределено Тогда
            Возврат Неопределено;
        КонецЕсли;

        Попытка
            ТекущееЗначение = ТекущееЗначение[СегментПути];
        Исключение
            Возврат Неопределено;
        КонецПопытки;
    КонецЦикла;

    Возврат ТекущееЗначение;

КонецФункции


Функция НормализоватьПутьДляОбъекта(ПутьКДанным)

    Если ЭтоПустаяСтрока(ПутьКДанным) Тогда
        Возврат "";
    КонецЕсли;

    Если Лев(ПутьКДанным, 7) = "Object." Тогда
        Возврат Сред(ПутьКДанным, 8);
    КонецЕсли;

    Если Лев(ПутьКДанным, 7) = "Объект." Тогда
        Возврат Сред(ПутьКДанным, 8);
    КонецЕсли;

    Если Лев(ПутьКДанным, 11) = "ThisObject." Тогда
        Возврат Сред(ПутьКДанным, 12);
    КонецЕсли;

    Возврат ПутьКДанным;

КонецФункции


Функция ПолучитьПредставлениеЗначенияПоПути(Форма, ПутьКДанным)

    Возврат ПредставлениеЗначения(ПолучитьЗначениеПоПутиФормы(Форма, ПутьКДанным));

КонецФункции


Функция БезопасноВыполнитьВыражение(Выражение, ЗначениеПоУмолчанию = Неопределено)

    Попытка
        Возврат Вычислить(Выражение);
    Исключение
        Возврат ЗначениеПоУмолчанию;
    КонецПопытки;

КонецФункции


Функция ИндексСодержитКлюч(Индекс, Ключ)

    Если Индекс = Неопределено Тогда
        Возврат Ложь;
    КонецЕсли;

    Попытка
        Возврат Индекс.Получить(Ключ) <> Неопределено;
    Исключение
    КонецПопытки;

    Возврат Ложь;

КонецФункции


Функция УникализироватьСтроковыйМассив(МассивСтрок)

    Результат = Новый Массив;
    Индекс = Новый Соответствие;

    Для Каждого Значение Из МассивСтрок Цикл
        СтроковоеЗначение = ЗначениеВСтроку(Значение);
        Если ЭтоПустаяСтрока(СтроковоеЗначение) Тогда
            Продолжить;
        КонецЕсли;

        Если Не ИндексСодержитКлюч(Индекс, СтроковоеЗначение) Тогда
            Индекс.Вставить(СтроковоеЗначение, Истина);
            Результат.Добавить(СтроковоеЗначение);
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;

КонецФункции


Функция ПолучитьСтрокуИзСтруктуры(СтруктураДанных, Имя, ЗначениеПоУмолчанию = "")

    Возврат ЗначениеВСтроку(ПолучитьПараметр(СтруктураДанных, Имя, ЗначениеПоУмолчанию));

КонецФункции


Функция ПолучитьБулевоИзСтруктуры(СтруктураДанных, Имя, ЗначениеПоУмолчанию = Ложь)

    Значение = ПолучитьПараметр(СтруктураДанных, Имя, ЗначениеПоУмолчанию);

    Если ТипЗнч(Значение) = Тип("Булево") Тогда
        Возврат Значение;
    КонецЕсли;

    Возврат ЗначениеПоУмолчанию;

КонецФункции


Функция ЭтоПустаяСтрока(Значение)

    Возврат СтрДлина(СокрЛП(ЗначениеВСтроку(Значение))) = 0;

КонецФункции


Функция ПоследнийСегментПути(Путь)

    Если ЭтоПустаяСтрока(Путь) Тогда
        Возврат "";
    КонецЕсли;

    МассивЧастей = СтрРазделить(Путь, ".");
    Если МассивЧастей.Количество() = 0 Тогда
        Возврат Путь;
    КонецЕсли;

    Возврат МассивЧастей[МассивЧастей.Количество() - 1];

КонецФункции


Функция ПерваяЗаполненнаяСтрока(Значение1 = "", Значение2 = "", Значение3 = "")

    Если Не ЭтоПустаяСтрока(СокрЛП(ЗначениеВСтроку(Значение1))) Тогда
        Возврат ЗначениеВСтроку(Значение1);
    КонецЕсли;

    Если Не ЭтоПустаяСтрока(СокрЛП(ЗначениеВСтроку(Значение2))) Тогда
        Возврат ЗначениеВСтроку(Значение2);
    КонецЕсли;

    Возврат ЗначениеВСтроку(Значение3);

КонецФункции


Функция ЗначениеВСтроку(Значение)

    Если Значение = Неопределено Тогда
        Возврат "";
    КонецЕсли;

    Попытка
        Возврат СокрЛП(Строка(Значение));
    Исключение
        Возврат "";
    КонецПопытки;

КонецФункции


Функция ТипЗначенияВСтроку(Значение)

    Если Значение = Неопределено Тогда
        Возврат "";
    КонецЕсли;

    Попытка
        Возврат Строка(ТипЗнч(Значение));
    Исключение
        Возврат "";
    КонецПопытки;

КонецФункции


Функция ПредставлениеЗначения(Значение)

    Если Значение = Неопределено Тогда
        Возврат "";
    КонецЕсли;

    Если ТипЗнч(Значение) = Тип("Строка") Тогда
        Возврат Значение;
    КонецЕсли;

    Попытка
        Возврат Строка(Значение);
    Исключение
        Возврат "";
    КонецПопытки;

КонецФункции


Функция ПреобразоватьВJSONСтроку(Данные)

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);

    Возврат ЗаписьJSON.Закрыть();

КонецФункции

#КонецЕсли
