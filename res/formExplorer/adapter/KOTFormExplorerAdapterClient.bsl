Функция ПолучитьЗначениеИзТекущихДанныхЭлемента(Элемент, ПутьКДанным)

    ТекущийЭлемент = Элемент;
    ИмяКолонки = ПоследнийСегментПути(ПутьКДанным);
    Если ЭтоПустаяСтрока(ИмяКолонки) Тогда
        ИмяКолонки = ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент));
    КонецЕсли;

    Пока ТекущийЭлемент <> Неопределено Цикл
        ТекущиеДанные = ПолучитьТекущиеДанныеЭлемента(ТекущийЭлемент);
        Если ТекущиеДанные <> Неопределено Тогда
            Если Не ЭтоПустаяСтрока(ИмяКолонки) Тогда
                Попытка
                    Возврат ТекущиеДанные[ИмяКолонки];
                Исключение
                КонецПопытки;
            КонецЕсли;

            НормализованныйПуть = НормализоватьПутьДляОбъекта(ПутьКДанным);
            Значение = ПолучитьЗначениеПоПутиОбъекта(ТекущиеДанные, НормализованныйПуть);
            Если Значение <> Неопределено Тогда
                Возврат Значение;
            КонецЕсли;
        КонецЕсли;

        ТекущийЭлемент = ПолучитьРодителяЭлемента(ТекущийЭлемент);
    КонецЦикла;

    Возврат Неопределено;

КонецФункции


