КонецФункции


Функция ПолучитьПредставлениеЗначенияЭлемента(Форма, Элемент, ПутьКДанным)

    КандидатыПутей = ПолучитьКандидатыПутиДанныхЭлемента(Элемент, ПутьКДанным);

    Для Каждого КандидатПути Из КандидатыПутей Цикл
        Значение = ПолучитьЗначениеПоПутиФормы(Форма, КандидатПути);
        Если Значение <> Неопределено Тогда
            Возврат ПредставлениеЗначения(Значение);
        КонецЕсли;
    КонецЦикла;

    Значение = ПолучитьЗначениеЭлементаНапрямую(Элемент);
    Если Значение <> Неопределено Тогда
        Возврат ПредставлениеЗначения(Значение);
    КонецЕсли;

    ИмяЭлемента = ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент));
    Значение = ПолучитьЗначениеФормыПоИмени(Форма, ИмяЭлемента);
    Если Значение <> Неопределено Тогда
        Возврат ПредставлениеЗначения(Значение);
    КонецЕсли;

    Для Каждого КандидатПути Из КандидатыПутей Цикл
        Значение = ПолучитьЗначениеИзТекущихДанныхЭлемента(Элемент, КандидатПути);
        Если Значение <> Неопределено Тогда
            Возврат ПредставлениеЗначения(Значение);
        КонецЕсли;
    КонецЦикла;

    ОтображаемыйТекст = ПолучитьОтображаемыйТекстЭлемента(Элемент);
    Если Не ЭтоПустаяСтрока(ОтображаемыйТекст) Тогда
        Возврат ОтображаемыйТекст;
    КонецЕсли;

    Возврат "";

КонецФункции


Функция ПолучитьТабличныеДанныеЭлемента(Форма, Элемент, ПутьКДанным)

    КандидатыПутей = ПолучитьКандидатыПутиДанныхЭлемента(Элемент, ПутьКДанным);

    Для Каждого КандидатПути Из КандидатыПутей Цикл
        Значение = ПолучитьЗначениеПоПутиФормы(Форма, КандидатПути);
        ТабличныеДанные = ПопытатьсяСериализоватьТабличныеДанные(Значение);
        Если ТабличныеДанные <> Неопределено Тогда
            ТабличныеДанные.Вставить("sourcePath", КандидатПути);
            Возврат ТабличныеДанные;
        КонецЕсли;
    КонецЦикла;

    Значение = ПолучитьЗначениеЭлементаНапрямую(Элемент);
    ТабличныеДанные = ПопытатьсяСериализоватьТабличныеДанные(Значение);
    Если ТабличныеДанные <> Неопределено Тогда
        ТабличныеДанные.Вставить("sourcePath", "element-direct");
        Возврат ТабличныеДанные;
    КонецЕсли;

    ИмяЭлемента = ЗначениеВСтроку(ПолучитьИмяЭлемента(Элемент));
    Если Не ЭтоПустаяСтрока(ИмяЭлемента) Тогда
        Значение = ПолучитьЗначениеФормыПоИмени(Форма, ИмяЭлемента);
        ТабличныеДанные = ПопытатьсяСериализоватьТабличныеДанные(Значение);
        Если ТабличныеДанные <> Неопределено Тогда
            ТабличныеДанные.Вставить("sourcePath", ИмяЭлемента);
            Возврат ТабличныеДанные;
        КонецЕсли;
    КонецЕсли;

    Для Каждого КандидатПути Из КандидатыПутей Цикл
        Значение = ПолучитьЗначениеИзТекущихДанныхЭлемента(Элемент, КандидатПути);
        ТабличныеДанные = ПопытатьсяСериализоватьТабличныеДанные(Значение);
        Если ТабличныеДанные <> Неопределено Тогда
            ТабличныеДанные.Вставить("sourcePath", "CurrentData." + КандидатПути);
            Возврат ТабличныеДанные;
        КонецЕсли;
    КонецЦикла;

    Для Каждого ИмяСвойства Из ПолучитьИменаСвойствТабличныхИсточников() Цикл
        Значение = ПолучитьЗначениеСвойства(Элемент, ИмяСвойства);
        ТабличныеДанные = ПопытатьсяСериализоватьТабличныеДанные(Значение);
        Если ТабличныеДанные <> Неопределено Тогда
            ТабличныеДанные.Вставить("sourcePath", "element." + ИмяСвойства);
            Возврат ТабличныеДанные;
        КонецЕсли;
    КонецЦикла;

    Возврат Неопределено;

КонецФункции


Функция ПопытатьсяСериализоватьТабличныеДанные(Значение, КолонкиПодсказки = Неопределено)

    Таблица = ПопытатьсяПреобразоватьВТаблицуЗначений(Значение);
    Если Таблица <> Неопределено Тогда
        Возврат СериализоватьТаблицуЗначений(Таблица);
    КонецЕсли;

    Возврат СериализоватьКоллекциюСтрок(Значение, КолонкиПодсказки);

КонецФункции


Функция ПопытатьсяПреобразоватьВТаблицуЗначений(Значение, Глубина = 0)

    Если Значение = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    Если Глубина > 3 Тогда
        Возврат Неопределено;
    КонецЕсли;

    Попытка
        Если Значение.Колонки <> Неопределено Тогда
            Возврат Значение;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Таблица = Значение.Выгрузить();
        Если Таблица <> Неопределено Тогда
            Возврат ПопытатьсяПреобразоватьВТаблицуЗначений(Таблица, Глубина + 1);
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Таблица = Значение.Выгрузить(Новый Массив);
        Если Таблица <> Неопределено Тогда
            Возврат ПопытатьсяПреобразоватьВТаблицуЗначений(Таблица, Глубина + 1);
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Таблица = Значение.ПолучитьИсполняемыеДанные();
        Если Таблица <> Неопределено Тогда
            Возврат ПопытатьсяПреобразоватьВТаблицуЗначений(Таблица, Глубина + 1);
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Таблица = Значение.GetExecutableData();
        Если Таблица <> Неопределено Тогда
            Возврат ПопытатьсяПреобразоватьВТаблицуЗначений(Таблица, Глубина + 1);
        КонецЕсли;
    Исключение
    КонецПопытки;

    Для Каждого ИмяСвойства Из ПолучитьИменаСвойствТабличныхИсточников() Цикл
        ВложенноеЗначение = ПолучитьЗначениеСвойства(Значение, ИмяСвойства);
        Если ВложенноеЗначение = Неопределено Или ВложенноеЗначение = Значение Тогда
            Продолжить;
        КонецЕсли;

        Таблица = ПопытатьсяПреобразоватьВТаблицуЗначений(ВложенноеЗначение, Глубина + 1);
        Если Таблица <> Неопределено Тогда
            Возврат Таблица;
        КонецЕсли;
    КонецЦикла;

    Возврат Неопределено;

КонецФункции


